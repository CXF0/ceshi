# Server
NODE_ENV=development
PORT=3000
GLOBAL_PREFIX=api

# Database (required)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=your_db_name
DB_LOGGING=false
DB_TIMEZONE=+08:00

# JWT (required)
JWT_SECRET=replace_with_a_strong_random_secret
JWT_EXPIRES_IN=7d

# Upload path
UPLOAD_PATH=./uploads
